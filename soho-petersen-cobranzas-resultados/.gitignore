# Archivos de datos y resultados generados
# Ignorar todos los contenidos, pero mantener los .gitkeep

# Carpeta de datos de entrada (CSV de Retell)
retell/**
!retell/.gitkeep

# Carpeta de archivos de debug (gestiones totales por fecha)
debug/**
!debug/.gitkeep

# Carpeta de promesas válidas (archivos finales validados)
gestiones-validas/**
!gestiones-validas/.gitkeep

# Carpeta de promesas válidas con fechas originales (nuevo flujo)
gestiones-validas-fecha-original/**
!gestiones-validas-fecha-original/.gitkeep

# ROMAN - Carpeta de historial de llamadas
roman/**
!roman/.gitkeep

# Carpeta de reporte de approach
approach/**
!approach/.gitkeep

# Carpeta de base de datos
base/**
!base/.gitkeep

# Carpeta de datos excluidos
datos-excluidos/*
!datos-excluidos/.gitkeep

# Variables de entorno
.env

# Entorno virtual de Python
.venv/
venv/
env/
ENV/

# Archivos compilados de Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/

# IDEs y editores
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code
.claude/

# Agent tooling artifacts
.atl/

# Archivos temporales del sistema
*.log
*.tmp
.DS_Store
Thumbs.db
nul

# Jupyter Notebook
.ipynb_checkpoints
