############################################
# Ejemplo de configuración para back-resultados
# Copiá este archivo como ".env" dentro de back-resultados/ (NO se sube al repo)
############################################

# Requerida: API key de Retell del MISMO workspace que generó el export
RETELL_API_KEY=pegá_tu_api_key_acá

# Opcional: URL base de Retell (default: https://api.retellai.com)
RETELL_BASE_URL=https://api.retellai.com

# Opcional: cómo se autentica
# Default:
#   Authorization: Bearer <RETELL_API_KEY>
RETELL_AUTH_HEADER=Authorization
RETELL_AUTH_SCHEME=Bearer

# Opcional: endpoint/path para obtener una llamada por call_id.
# Podés poner varios templates separados por coma; el script prueba en orden hasta que alguno funcione.
#
# Si estás viendo 404 con /v2/calls/{call_id}, probá priorizar /v2/get-call/{call_id}:
RETELL_CALL_PATH_TEMPLATE=/v2/get-call/{call_id},/v2/calls/{call_id},/calls/{call_id},/call/{call_id}

# Opcional: timeout por request (segundos)
RETELL_TIMEOUT_SECONDS=30

# Opcional: pausa entre requests (segundos) para rate limit
RETELL_SLEEP_SECONDS=0.0

# Opcional: logs de debug (1/true/yes)
RETELL_DEBUG=0

############################################
# Configuración de ROMAN (opcional)
############################################

# Opcional: patrón de archivos ROMAN (default: export_roman_*.csv)
# El sistema busca en back-resultados/roman/ el archivo más reciente que coincida
ROMAN_GLOB_PATTERN=export_roman_*.csv
