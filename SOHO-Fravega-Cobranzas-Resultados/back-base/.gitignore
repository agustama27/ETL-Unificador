# Ignorar contenidos de las carpetas base_recibida y base_procesada
# (pero mantener las carpetas con .gitkeep)

base_recibida/*
!base_recibida/.gitkeep

base_procesada/*
!base_procesada/.gitkeep

# Archivos temporales y de Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Entornos virtuales
venv/
env/
ENV/

# Archivos de configuración local
.env
.env.local

# Archivos de debug
*.log
debug_*.py

